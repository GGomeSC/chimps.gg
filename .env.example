# Supabase project settings → API Keys
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# SERVER-ONLY (sb_secret_..., bypasses RLS). 
# Never import outside src/lib/server, *.server.ts, or scripts/.
SUPABASE_SECRET_KEY=your-secret-key
# SERVER-ONLY. Supavisor transaction-mode connection (port 6543, SSL enabled).
DATABASE_URL=postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# SERVER-ONLY. Random value containing at least 32 bytes.
INTERNAL_SERVICE_SECRET=replace-with-at-least-32-random-bytes
# Vercel Cron bearer secret. Use a different random value from the internal service secret.
CRON_SECRET=replace-with-a-separate-random-secret
# Ninja Kiwi Open Data API root.
NK_API_ROOT=https://data.ninjakiwi.com
# Canonical production origin used by public metadata and sitemap generation.
PUBLIC_SITE_URL=https://chimps.gg
