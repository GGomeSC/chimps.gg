{
	"name": "chimps-gg",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.11.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "pnpm run i18n:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"discover:nk": "node --env-file=.env --import=tsx scripts/discover-nk.ts",
		"sync:maps": "node --env-file=.env --import=tsx scripts/sync-maps.ts",
		"setup:tower-icons": "node --env-file=.env --import=tsx scripts/ensure-tower-icons-bucket.ts",
		"check:tower-icons": "node --env-file=.env --import=tsx scripts/check-tower-icons.ts"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.21.0",
		"@sveltejs/adapter-vercel": "6.3.4",
		"@sveltejs/kit": "2.69.2",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@types/node": "26.1.1",
		"supabase": "2.109.1",
		"svelte": "5.56.4",
		"svelte-check": "4.7.2",
		"tsx": "4.23.0",
		"typescript": "6.0.3",
		"vite": "8.1.4"
	},
	"dependencies": {
		"@fontsource-variable/bricolage-grotesque": "^5.2.10",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@opentelemetry/api": "1.9.1",
		"@supabase/ssr": "0.12.0",
		"@supabase/supabase-js": "2.110.2",
		"@vercel/analytics": "2.0.1",
		"@vercel/functions": "3.7.5",
		"@vercel/speed-insights": "^2.0.0"
	}
}
